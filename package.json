{
  "name": "brojo-bot",
  "version": "1.0.0",
  "description": "BrojoWizard — Discord TLDR summarizer bot powered by Gemini 3 Flash",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "register": "node src/commands/register.js",
    "test": "node --test src/**/*.test.js",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1",
    "deploy:skip-build": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1 -SkipBuild",
    "testbed": "node testbed/run.js",
    "testbed:dry": "node testbed/run.js --dry-run",
    "testbed:all": "node testbed/run.js --all",
    "testbed:capture": "node testbed/capture.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ellio/BrojoWizard.git"
  },
  "keywords": [
    "discord",
    "bot",
    "tldr",
    "summarizer",
    "gemini"
  ],
  "author": "ellio",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.49.0",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0"
  }
}
